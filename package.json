{
  "name": "@matter/dcl-data",
  "version": "0.0.0",
  "type": "module",
  "description": "Daily snapshot of Matter DCL data for seeding matter.js services",
  "license": "Apache-2.0",
  "engines": { "node": ">=18" },
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": ["dist", "data", "manifest.json"],
  "scripts": {
    "build": "nacho-build",
    "build-clean": "nacho-build --clean",
    "test": "matter-test",
    "format": "oxfmt \"src/**/*.ts\" \"tools/**/*.ts\" \"tests/**/*.ts\"",
    "format-verify": "oxfmt --check \"src/**/*.ts\" \"tools/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "oxlint --type-aware",
    "lint-fix": "oxlint --fix --type-aware",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "mocha": {
      "diff": "^8.0.3",
      "serialize-javascript": "^7.0.4"
    }
  },
  "devDependencies": {
    "@matter/main": "dev",
    "@matter/testing": "dev",
    "@nacho-iot/js-tools": "^0.1.7",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.0",
    "typescript": "^5.7.0"
  }
}
