{
    "name": "@matter/dcl-data",
    "version": "2026.5.30",
    "type": "module",
    "description": "Daily snapshot of Matter DCL data for seeding matter.js services",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/matter-js/dcl-data.git"
    },
    "engines": {
        "node": ">=18"
    },
    "exports": {
        ".": {
            "types": "./dist/esm/types.d.ts",
            "default": "./dist/esm/types.js"
        },
        "./node": {
            "types": "./dist/esm/node.d.ts",
            "default": "./dist/esm/node.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist",
        "data",
        "manifest.json",
        "LICENSE"
    ],
    "scripts": {
        "build": "nacho-build",
        "build-clean": "nacho-build --clean",
        "test": "matter-test",
        "format": "oxfmt \"src/**/*.ts\" \"tools/**/*.ts\" \"test/**/*.ts\"",
        "format-verify": "oxfmt --check \"src/**/*.ts\" \"tools/**/*.ts\" \"test/**/*.ts\"",
        "lint": "oxlint --type-aware",
        "lint-fix": "oxlint --fix --type-aware"
    },
    "overrides": {
        "mocha": {
            "diff": "^8.0.3",
            "serialize-javascript": "^7.0.4"
        }
    },
    "devDependencies": {
        "@matter/main": "dev",
        "@matter/testing": "dev",
        "@nacho-iot/js-tools": "^0.1.7",
        "@types/chai": "^4.3.20",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.9.1",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "oxlint-tsgolint": "^0.23.0",
        "typescript": "^6.0.3"
    }
}
